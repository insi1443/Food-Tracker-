# Copy this file to ".env" and paste your real keys after the "=" signs.
# The real .env file is git-ignored, so your keys never get pushed to GitHub.

# USDA FoodData Central (typed search). Free key: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your_usda_key_here

# Anthropic / Claude (analyses food photos). Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here
